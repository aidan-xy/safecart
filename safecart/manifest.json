{
  "manifest_version": 3,
  "name": "Safecart",
  "description": "SafeCart is a browser extension designed to help users safely navigate online marketplaces (currently focused on AliExpress).",
  "version": "1.0",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_popup": "dist/safecart/popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.aliexpress.com/*",
        "*://*.aliexpress.us/*"
      ],
      "js": ["dist/assets/contentScript.js"],
      "type": "module"
    },
    {
      "js": ["scripts/scanner.js"],
      "matches": [
        "https://www.aliexpress.us/item/*",
        "https://www.aliexpress.com/item/*",
        "https://www.aliexpress.us/w/wholesale*",
        "https://www.aliexpress.com/w/wholesale*",
        "https://www.aliexpress.com/ssr/*",
        "https://www.aliexpress.us/ssr/*"
      ],
      "type":"module"
    }
  ],  
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "permissions": ["activeTab", "scripting", "offscreen","tabs"],
  "host_permissions": [
    "https://www.aliexpress.us/*",
    "https://www.aliexpress.com/*",
    "https://www.aliexpress.us/w/wholesale*",
    "https://www.aliexpress.com/w/wholesale*",
    "https://www.aliexpress.com/ssr/*",
    "https://www.aliexpress.us/ssr/*",
    "https://www.aliexpress/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["trust_model.onnx", "dist/assets/popup.css"],
      "matches": ["<all_urls>"]
    }
  ],
  "background": {
    "service_worker": "scripts/background.js"
  }
}